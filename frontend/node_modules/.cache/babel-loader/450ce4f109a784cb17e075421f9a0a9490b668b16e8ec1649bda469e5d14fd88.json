{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nexport default {\n  name: \"Role\",\n  data() {\n    return {\n      searchForm: {},\n      delBtlStatu: true,\n      total: 0,\n      size: 10,\n      current: 1,\n      dialogVisible: false,\n      editForm: {},\n      tableData: [],\n      editFormRules: {\n        username: [{\n          required: true,\n          message: 'иҜ·иҫ“е…Ҙз”ЁжҲ·еҗҚз§°',\n          trigger: 'blur'\n        }],\n        email: [{\n          required: true,\n          message: 'иҜ·иҫ“е…ҘйӮ®з®ұ',\n          trigger: 'blur'\n        }],\n        statu: [{\n          required: true,\n          message: 'иҜ·йҖүжӢ©зҠ¶жҖҒ',\n          trigger: 'blur'\n        }]\n      },\n      multipleSelection: [],\n      roleDialogFormVisible: false,\n      defaultProps: {\n        children: 'children',\n        label: 'name'\n      },\n      roleForm: {},\n      roleTreeData: [],\n      treeCheckedKeys: [],\n      checkStrictly: true\n    };\n  },\n  created() {\n    this.getUserList();\n    this.$axios.get(\"/sys/role/list\").then(res => {\n      this.roleTreeData = res.data.data.records;\n      console.log(this.roleTreeData);\n    });\n  },\n  methods: {\n    toggleSelection(rows) {\n      if (rows) {\n        rows.forEach(row => {\n          this.$refs.multipleTable.toggleRowSelection(row);\n        });\n      } else {\n        this.$refs.multipleTable.clearSelection();\n      }\n    },\n    handleSelectionChange(val) {\n      console.log(\"еӢҫйҖү\");\n      console.log(val);\n      this.multipleSelection = val;\n      this.delBtlStatu = val.length == 0;\n    },\n    handleSizeChange(val) {\n      console.log(`жҜҸйЎө ${val} жқЎ`);\n      this.size = val;\n      this.getUserList();\n    },\n    handleCurrentChange(val) {\n      console.log(`еҪ“еүҚйЎө: ${val}`);\n      this.current = val;\n      this.getUserList();\n    },\n    resetForm(formName) {\n      this.$refs[formName].resetFields();\n      this.dialogVisible = false;\n      this.editForm = {};\n    },\n    handleClose() {\n      this.resetForm('editForm');\n    },\n    getUserList() {\n      this.$axios.get(\"/sys/user/list\", {\n        params: {\n          username: this.searchForm.username,\n          current: this.current,\n          size: this.size\n        }\n      }).then(res => {\n        this.tableData = res.data.data.records;\n        this.size = res.data.data.size;\n        this.current = res.data.data.current;\n        this.total = res.data.data.total;\n      });\n    },\n    submitForm(formName) {\n      this.$refs[formName].validate(valid => {\n        if (valid) {\n          this.$axios.post('/sys/user/' + (this.editForm.id ? 'update' : 'save'), this.editForm).then(res => {\n            this.$message({\n              showClose: true,\n              message: 'жҒӯе–ңдҪ пјҢж“ҚдҪңжҲҗеҠҹ',\n              type: 'success',\n              onClose: () => {\n                this.getUserList();\n              }\n            });\n            this.resetForm('editForm');\n            this.dialogVisible = false;\n          }).catch(err => {});\n        } else {\n          console.log('error submit!!');\n          return false;\n        }\n      });\n    },\n    editHandle(id) {\n      this.$axios.get('/sys/user/info/' + id).then(res => {\n        this.editForm = res.data.data;\n        this.dialogVisible = true;\n      });\n    },\n    delHandle(id) {\n      var ids = [];\n      if (id) {\n        ids.push(id);\n      } else {\n        this.multipleSelection.forEach(row => {\n          ids.push(row.id);\n        });\n      }\n      console.log(ids);\n      this.$axios.post(\"/sys/user/delete\", ids).then(res => {\n        this.$message({\n          showClose: true,\n          message: 'жҒӯе–ңдҪ пјҢж“ҚдҪңжҲҗеҠҹ',\n          type: 'success',\n          onClose: () => {\n            this.getUserList();\n          }\n        });\n      });\n    },\n    roleHandle(id) {\n      this.roleDialogFormVisible = true;\n      this.$axios.get('/sys/user/info/' + id).then(res => {\n        this.roleForm = res.data.data;\n        let roleIds = [];\n        res.data.data.sysRoles.forEach(row => {\n          roleIds.push(row.id);\n        });\n        this.$refs.roleTree.setCheckedKeys(roleIds);\n      });\n    },\n    submitRoleHandle(formName) {\n      var roleIds = this.$refs.roleTree.getCheckedKeys();\n      console.log(roleIds);\n      this.$axios.post('/sys/user/role/' + this.roleForm.id, roleIds).then(res => {\n        this.$message({\n          showClose: true,\n          message: 'жҒӯе–ңдҪ пјҢж“ҚдҪңжҲҗеҠҹ',\n          type: 'success',\n          onClose: () => {\n            this.getUserList();\n          }\n        });\n        this.roleDialogFormVisible = false;\n      });\n    },\n    repassHandle(id, username) {\n      this.$confirm('е°ҶйҮҚзҪ®з”ЁжҲ·гҖҗ' + username + 'гҖ‘зҡ„еҜҶз Ғ, жҳҜеҗҰз»§з»ӯ?', 'жҸҗзӨә', {\n        confirmButtonText: 'зЎ®е®ҡ',\n        cancelButtonText: 'еҸ–ж¶Ҳ',\n        type: 'warning'\n      }).then(() => {\n        return this.$axios.post(\"/sys/user/repass\", id);\n      }).then(res => {\n        this.$message({\n          showClose: true,\n          message: 'жҒӯе–ңдҪ пјҢж“ҚдҪңжҲҗеҠҹ',\n          type: 'success'\n        });\n      }).catch(err => {\n        if (err !== 'cancel') {\n          // иҝҮж»ӨжҺүз”ЁжҲ·еҸ–ж¶Ҳзҡ„жғ…еҶө\n          console.error('ж“ҚдҪңеӨұиҙҘ:', err);\n        }\n      });\n    }\n  }\n};","map":{"version":3,"names":["name","data","searchForm","delBtlStatu","total","size","current","dialogVisible","editForm","tableData","editFormRules","username","required","message","trigger","email","statu","multipleSelection","roleDialogFormVisible","defaultProps","children","label","roleForm","roleTreeData","treeCheckedKeys","checkStrictly","created","getUserList","$axios","get","then","res","records","console","log","methods","toggleSelection","rows","forEach","row","$refs","multipleTable","toggleRowSelection","clearSelection","handleSelectionChange","val","length","handleSizeChange","handleCurrentChange","resetForm","formName","resetFields","handleClose","params","submitForm","validate","valid","post","id","$message","showClose","type","onClose","catch","err","editHandle","delHandle","ids","push","roleHandle","roleIds","sysRoles","roleTree","setCheckedKeys","submitRoleHandle","getCheckedKeys","repassHandle","$confirm","confirmButtonText","cancelButtonText","error"],"sources":["src/views/sys/User.vue"],"sourcesContent":["<template>\r\n\t<div>\r\n\t\t<el-form :inline=\"true\">\r\n\t\t\t<el-form-item>\r\n\t\t\t\t<el-input\r\n\t\t\t\t\t\tv-model=\"searchForm.username\"\r\n\t\t\t\t\t\tplaceholder=\"з”ЁжҲ·еҗҚ\"\r\n\t\t\t\t\t\tclearable\r\n\t\t\t\t>\r\n\t\t\t\t</el-input>\r\n\t\t\t</el-form-item>\r\n\r\n\t\t\t<el-form-item>\r\n\t\t\t\t<el-button @click=\"getUserList\">жҗңзҙў</el-button>\r\n\t\t\t</el-form-item>\r\n\r\n\t\t\t<el-form-item>\r\n\t\t\t\t<el-button type=\"primary\" @click=\"dialogVisible = true\" v-if=\"hasAuth('sys:user:save')\" >ж–°еўһ</el-button>\r\n\t\t\t</el-form-item>\r\n\t\t\t<el-form-item>\r\n\t\t\t\t<el-popconfirm title=\"иҝҷжҳҜзЎ®е®ҡжү№йҮҸеҲ йҷӨеҗ—пјҹ\" @confirm=\"delHandle(null)\">\r\n\t\t\t\t\t<el-button type=\"danger\" slot=\"reference\" :disabled=\"delBtlStatu\" v-if=\"hasAuth('sys:user:delete')\">жү№йҮҸеҲ йҷӨ</el-button>\r\n\t\t\t\t</el-popconfirm>\r\n\t\t\t</el-form-item>\r\n\t\t</el-form>\r\n\r\n\t\t<el-table\r\n\t\t\t\tref=\"multipleTable\"\r\n\t\t\t\t:data=\"tableData\"\r\n\t\t\t\ttooltip-effect=\"dark\"\r\n\t\t\t\tstyle=\"width: 100%\"\r\n\t\t\t\tborder\r\n\t\t\t\tstripe\r\n\t\t\t\t@selection-change=\"handleSelectionChange\">\r\n\r\n\t\t\t<el-table-column\r\n\t\t\t\t\ttype=\"selection\"\r\n\t\t\t\t\twidth=\"55\">\r\n\t\t\t</el-table-column>\r\n\r\n\t\t\t<el-table-column\r\n\t\t\t\t\tlabel=\"еӨҙеғҸ\"\r\n\t\t\t\t\twidth=\"50\">\r\n\t\t\t\t<template slot-scope=\"scope\">\r\n\t\t\t\t\t<el-avatar size=\"small\" :src=\"scope.row.avatar\"></el-avatar>\r\n\t\t\t\t</template>\r\n\t\t\t</el-table-column>\r\n\r\n\t\t\t<el-table-column\r\n\t\t\t\t\tprop=\"username\"\r\n\t\t\t\t\tlabel=\"з”ЁжҲ·еҗҚ\"\r\n\t\t\t\t\twidth=\"120\">\r\n\t\t\t</el-table-column>\r\n\t\t\t<el-table-column\r\n\t\t\t\t\tprop=\"code\"\r\n\t\t\t\t\tlabel=\"и§’иүІеҗҚз§°\">\r\n\t\t\t\t<template slot-scope=\"scope\" >\r\n\t\t\t\t\t<el-tag size=\"small\" type=\"info\" v-for=\"item in scope.row.sysRoles\">{{item.name}}</el-tag>\r\n\t\t\t\t</template>\r\n\r\n\t\t\t</el-table-column>\r\n\t\t\t<el-table-column\r\n\t\t\t\t\tprop=\"email\"\r\n\t\t\t\t\tlabel=\"йӮ®з®ұ\">\r\n\t\t\t</el-table-column>\r\n\t\t\t<el-table-column\r\n\t\t\t\t\tprop=\"phone\"\r\n\t\t\t\t\tlabel=\"жүӢжңәеҸ·\">\r\n\t\t\t</el-table-column>\r\n\r\n\t\t\t<el-table-column\r\n\t\t\t\t\tprop=\"statu\"\r\n\t\t\t\t\tlabel=\"зҠ¶жҖҒ\">\r\n\t\t\t\t<template slot-scope=\"scope\">\r\n\t\t\t\t\t<el-tag size=\"small\" v-if=\"scope.row.statu === 1\" type=\"success\">жӯЈеёё</el-tag>\r\n\t\t\t\t\t<el-tag size=\"small\" v-else-if=\"scope.row.statu === 0\" type=\"danger\">зҰҒз”Ё</el-tag>\r\n\t\t\t\t</template>\r\n\r\n\t\t\t</el-table-column>\r\n\t\t\t<el-table-column\r\n\t\t\t\t\tprop=\"created\"\r\n\t\t\t\t\twidth=\"200\"\r\n\t\t\t\t\tlabel=\"еҲӣе»әж—¶й—ҙ\"\r\n\t\t\t>\r\n\t\t\t</el-table-column>\r\n\t\t\t<el-table-column\r\n\t\t\t\t\tprop=\"icon\"\r\n\t\t\t\t\twidth=\"260px\"\r\n\t\t\t\t\tlabel=\"ж“ҚдҪң\">\r\n\r\n\t\t\t\t<template slot-scope=\"scope\">\r\n\t\t\t\t\t<el-button type=\"text\" @click=\"roleHandle(scope.row.id)\">еҲҶй…Қи§’иүІ</el-button>\r\n\t\t\t\t\t<el-divider direction=\"vertical\"></el-divider>\r\n\r\n\t\t\t\t\t<el-button type=\"text\" @click=\"repassHandle(scope.row.id, scope.row.username)\">йҮҚзҪ®еҜҶз Ғ</el-button>\r\n\t\t\t\t\t<el-divider direction=\"vertical\"></el-divider>\r\n\r\n\t\t\t\t\t<el-button type=\"text\" @click=\"editHandle(scope.row.id)\">зј–иҫ‘</el-button>\r\n\t\t\t\t\t<el-divider direction=\"vertical\"></el-divider>\r\n\r\n\t\t\t\t\t<template>\r\n\t\t\t\t\t\t<el-popconfirm title=\"иҝҷжҳҜдёҖж®өеҶ…е®№зЎ®е®ҡеҲ йҷӨеҗ—пјҹ\" @confirm=\"delHandle(scope.row.id)\">\r\n\t\t\t\t\t\t\t<el-button type=\"text\" slot=\"reference\">еҲ йҷӨ</el-button>\r\n\t\t\t\t\t\t</el-popconfirm>\r\n\t\t\t\t\t</template>\r\n\r\n\t\t\t\t</template>\r\n\t\t\t</el-table-column>\r\n\r\n\t\t</el-table>\r\n\r\n\t\t<el-pagination\r\n\t\t\t\t@size-change=\"handleSizeChange\"\r\n\t\t\t\t@current-change=\"handleCurrentChange\"\r\n\t\t\t\tlayout=\"total, sizes, prev, pager, next, jumper\"\r\n\t\t\t\t:page-sizes=\"[10, 20, 50, 100]\"\r\n\t\t\t\t:current-page=\"current\"\r\n\t\t\t\t:page-size=\"size\"\r\n\t\t\t\t:total=\"total\">\r\n\t\t</el-pagination>\r\n\r\n\r\n\t\t<!--ж–°еўһеҜ№иҜқжЎҶ-->\r\n\t\t<el-dialog\r\n\t\t\t\ttitle=\"жҸҗзӨә\"\r\n\t\t\t\t:visible.sync=\"dialogVisible\"\r\n\t\t\t\twidth=\"600px\"\r\n\t\t\t\t:before-close=\"handleClose\">\r\n\r\n\t\t\t<el-form :model=\"editForm\" :rules=\"editFormRules\" ref=\"editForm\">\r\n\t\t\t\t<el-form-item label=\"з”ЁжҲ·еҗҚ\" prop=\"username\" label-width=\"100px\">\r\n\t\t\t\t\t<el-input v-model=\"editForm.username\" autocomplete=\"off\"></el-input>\r\n\t\t\t\t\t<el-alert\r\n\t\t\t\t\t\t\ttitle=\"еҲқе§ӢеҜҶз Ғдёә888888\"\r\n\t\t\t\t\t\t\t:closable=\"false\"\r\n\t\t\t\t\t\t\ttype=\"info\"\r\n\t\t\t\t\t\t\tstyle=\"line-height: 12px;\"\r\n\t\t\t\t\t></el-alert>\r\n\t\t\t\t</el-form-item>\r\n\r\n\t\t\t\t<el-form-item label=\"йӮ®з®ұ\"  prop=\"email\" label-width=\"100px\">\r\n\t\t\t\t\t<el-input v-model=\"editForm.email\" autocomplete=\"off\"></el-input>\r\n\t\t\t\t</el-form-item>\r\n\t\t\t\t<el-form-item label=\"жүӢжңәеҸ·\"  prop=\"phone\" label-width=\"100px\">\r\n\t\t\t\t\t<el-input v-model=\"editForm.phone\" autocomplete=\"off\"></el-input>\r\n\t\t\t\t</el-form-item>\r\n\r\n\t\t\t\t<el-form-item label=\"зҠ¶жҖҒ\"  prop=\"statu\" label-width=\"100px\">\r\n\t\t\t\t\t<el-radio-group v-model=\"editForm.statu\">\r\n\t\t\t\t\t\t<el-radio :label=\"0\">зҰҒз”Ё</el-radio>\r\n\t\t\t\t\t\t<el-radi